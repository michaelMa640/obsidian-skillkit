{
  "_instructions": {
    "purpose": "Copy this file to local-config.json and edit it for the target machine.",
    "do_not_commit": "Do not commit local-config.json. It is machine-specific.",
    "must_update": [
      "obsidian.vault_path unless your workflow always passes a vault path at runtime",
      "routes.article.command if you wire a custom extractor instead of the built-in web article route",
      "clipper.default_folder if your vault does not use Clippings",
      "routes.social.auth.<platform>.storage_state_path and routes.social.auth.<platform>.cookies_file if you want separate login-state reuse for Douyin and Xiaohongshu"
    ],
    "notes": [
      "article uses the built-in web article route inside run_clipper.ps1 by default",
      "social uses python + scripts/capture_social_playwright.py and download_social_media.ps1 by default",
      "video_metadata uses yt-dlp by default",
      "podcast uses the built-in web metadata route inside run_clipper.ps1 and does not require a separate command"
    ]
  },
  "obsidian": {
    "mode": "filesystem",
    "vault_path": "E:/REPLACE/WITH/YOUR/ObsidianVault"
  },
  "clipper": {
    "default_folder": "Clippings",
    "prefix_date": true,
    "default_tag": "clipped",
    "attachments_root": "Attachments/ShortVideos",
    "podcast_attachments_root": "Attachments/Podcasts",
    "allow_category_hint_folder_override": false,
    "default_debug_directory": ".tmp/run-clipper"
  },
  "routes": {
    "article": {
      "built_in": true
    },
    "social": {
      "command": "python",
      "script": "E:/REPLACE/WITH/YOUR/obsidian-clipper/scripts/capture_social_playwright.py",
      "timeout_ms": 25000,
      "download_command": "yt-dlp",
      "xiaohongshu_adapter": {
        "command": "python",
        "script": "E:/REPLACE/WITH/YOUR/obsidian-clipper/scripts/xiaohongshu_downloader_adapter.py",
        "server_url": "http://127.0.0.1:5556/xhs/detail",
        "timeout_ms": 30000,
        "save_backend_payload": true
      },
      "auth": {
        "douyin": {
          "storage_state_path": "E:/REPLACE/WITH/YOUR/obsidian-clipper/.local-auth/douyin-storage-state.json",
          "cookies_file": "E:/REPLACE/WITH/YOUR/obsidian-clipper/.local-auth/douyin-cookies.txt"
        },
        "xiaohongshu": {
          "storage_state_path": "E:/REPLACE/WITH/YOUR/obsidian-clipper/.local-auth/xiaohongshu-storage-state.json",
          "cookies_file": "E:/REPLACE/WITH/YOUR/obsidian-clipper/.local-auth/xiaohongshu-cookies.txt"
        }
      }
    },
    "video_metadata": {
      "command": "yt-dlp",
      "subtitle_languages": "all,-live_chat",
      "subtitle_format": "vtt/srt/best"
    },
    "podcast": {
      "built_in": true,
      "prefer_transcript": true,
      "prefer_show_notes": true,
      "download_audio": true,
      "download_timeout_sec": 60,
      "asr": {
        "enabled": false,
        "command": "python",
        "script": "E:/REPLACE/WITH/YOUR/obsidian-clipper/scripts/podcast_asr_fallback.py",
        "provider": "faster-whisper",
        "model": "base",
        "language": "zh",
        "device": "auto",
        "compute_type": "auto",
        "beam_size": 5,
        "vad_filter": true,
        "timeout_sec": 600,
        "mock_transcript_path": "E:/REPLACE/WITH/YOUR/obsidian-clipper/.tmp/mock-transcript.txt"
      }
    }
  }
}
