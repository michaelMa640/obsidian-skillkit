{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://obsidian-skillkit.local/ios-shortcuts-gateway/task-status.schema.json",
  "title": "Gateway Task Status",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "action",
    "status",
    "message_zh",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "enum": [
        "clip",
        "analyze"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ACCEPTED",
        "RUNNING",
        "SUCCESS",
        "PARTIAL",
        "FAILED",
        "AUTH_REQUIRED"
      ]
    },
    "message_zh": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "failed_step": {
      "type": "string"
    },
    "source_url": {
      "type": "string"
    },
    "normalized_url": {
      "type": "string"
    },
    "route": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "content_type": {
      "type": "string"
    },
    "source_input_kind": {
      "type": "string"
    },
    "source_url_extracted": {
      "type": "boolean"
    },
    "audio_download_status": {
      "type": "string"
    },
    "transcript_status": {
      "type": "string"
    },
    "transcript_source": {
      "type": "string"
    },
    "asr_status": {
      "type": "string"
    },
    "asr_provider": {
      "type": "string"
    },
    "original_source_text": {
      "type": "string"
    },
    "clipper_note": {
      "type": "string"
    },
    "analyzer_note": {
      "type": "string"
    },
    "auth_action_required": {
      "type": "string",
      "enum": [
        "refresh_douyin_auth"
      ]
    },
    "refresh_command": {
      "type": "string"
    },
    "debug_hint": {
      "type": "string"
    },
    "callback_attempted_at": {
      "type": "string"
    },
    "callback_sent": {
      "type": "boolean"
    },
    "callback_error": {
      "type": "string"
    }
  }
}
