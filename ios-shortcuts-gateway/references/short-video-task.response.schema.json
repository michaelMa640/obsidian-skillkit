{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://obsidian-skillkit.local/ios-shortcuts-gateway/short-video-task.response.schema.json",
  "title": "Share Task Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "success",
    "status",
    "action",
    "message_zh"
  ],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "FAILED",
        "PARTIAL",
        "AUTH_REQUIRED",
        "CONFIG_REQUIRED",
        "ACCEPTED",
        "RUNNING"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "clip",
        "analyze"
      ]
    },
    "message_zh": {
      "type": "string",
      "minLength": 1
    },
    "failed_step": {
      "type": "string"
    },
    "clipper_note": {
      "type": "string"
    },
    "analyzer_note": {
      "type": "string"
    },
    "debug_hint": {
      "type": "string"
    },
    "auth_action_required": {
      "type": "string",
      "enum": [
        "refresh_douyin_auth"
      ]
    },
    "refresh_command": {
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "source_url": {
      "type": "string"
    },
    "normalized_url": {
      "type": "string"
    },
    "route": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "content_type": {
      "type": "string"
    },
    "source_input_kind": {
      "type": "string"
    },
    "source_url_extracted": {
      "type": "boolean"
    },
    "audio_download_status": {
      "type": "string"
    },
    "transcript_status": {
      "type": "string"
    },
    "transcript_source": {
      "type": "string"
    },
    "asr_status": {
      "type": "string"
    },
    "asr_provider": {
      "type": "string"
    }
  }
}
